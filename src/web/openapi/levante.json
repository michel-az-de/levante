          }
        },
        "description": "Resposta de /auth/eu (admin autenticado)."
      },
      "ArtigoResponse": {
        "required": [
          "id",
          "titulo",
          "slug",
          "resumo",
          "conteudo",
          "dataPublicacao",
          "status",
          "metaTitulo",
          "metaDescricao",
          "imagemOgUrl",
          "categoriaId",
          "tags"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "titulo": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "resumo": {
            "type": "string"
          },
          "conteudo": {
            "type": "string"
          },
          "dataPublicacao": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "status": {
            "type": "string"
          },
          "metaTitulo": {
            "type": "string",
            "nullable": true
          },
          "metaDescricao": {
            "type": "string",
            "nullable": true
          },
          "imagemOgUrl": {
            "type": "string",
            "nullable": true
          },
          "categoriaId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "Contrato de saida do contexto Conteudo. Vira o tipo TS gerado do OpenAPI\n(PT) consumido pelo Next.js. Nao expor o agregado diretamente."
      },
      "AutenticarRequest": {
        "required": [
          "email",
          "senha"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "senha": {
            "type": "string"
          }
        },
        "description": "Corpo do login."
      },
      "CancelarNewsletterRequest": {
        "required": [
          "token"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "description": "Corpo do POST de cancelamento (token de descadastro)."
      },
      "CategoriaResponse": {
        "required": [
          "id",
          "nome",
          "slug",
          "descricao"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nome": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "descricao": {
            "type": "string",
            "nullable": true
          }
        },
        "description": "Contrato de saida da categoria (vira o tipo TS gerado do OpenAPI)."
      },
      "ComentarioResponse": {
        "required": [
          "id",
          "artigoId",
          "artigoSlug",
          "autor",
          "texto",
          "status",
          "dataCriacao"
