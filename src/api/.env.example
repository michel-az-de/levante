# Exemplo das variaveis de ambiente da API (Levante.Api) em container/producao.
# Em DEV local use user-secrets (`dotnet user-secrets`) em vez deste arquivo.
# NUNCA commitar valores reais: copie para .env (gitignored), chmod 600, e preencha.
# Nesting do ASP.NET Core = "__" (ex.: Mongo__ConnectionString == secao Mongo:ConnectionString).
# Na VM os valores reais vivem no .env da stack conjunta (Hiram deploy/stack), nao aqui.

# --- Obrigatorios no boot (fail-fast via ValidateOnStart) ---
# Cluster Mongo (replica set; Atlas em producao). O usuario de RUNTIME nao pode ter role
# administrativa: o self-check de boot ABORTA em Producao se tiver (regra de privilegio minimo).
Mongo__ConnectionString=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/levante?retryWrites=true&w=majority
Mongo__DatabaseName=levante
# Chave de assinatura do JWT admin (>= 32 chars). Gere com: openssl rand -hex 24
Jwt__SecretKey=CHANGE_ME_at_least_32_characters_long_secret
# Segredo do hash de origem (IP+UA) para dedup de reacoes (>= 32 chars). openssl rand -hex 24
Engajamento__OrigemHashSecret=CHANGE_ME_at_least_32_characters_long_secret

# --- Admin (seed do primeiro usuario) ---
Admin__Email=admin@exemplo.com
Admin__SenhaInicial=CHANGE_ME
# Opt-in para semear o admin em Producao (default false). true = cria o primeiro admin no boot
# a partir das vars acima (idempotente, semeia no maximo uma vez). Necessario na stack da VM.
Admin__PermitirSeedEmProducao=true

# --- Relay do Outbox -> Hiram (so emite com o relay habilitado) ---
Outbox__RelayHabilitado=true
# In-network na stack conjunta; o Hiram fica em loopback e nao e exposto publicamente.
Hiram__BaseUrl=http://hiram-api:8080
# Tenant key do Hiram (hk_live_..., emitida por provision-levante.sh, mostrada uma vez). Nunca no repo.
Hiram__ApiKey=CHANGE_ME
Levante__Notificacoes__AdminEmail=moderacao@exemplo.com
Levante__Notificacoes__SiteUrl=https://levante.exemplo.com

# --- Borda / CORS (origens do browser permitidas) ---
Cors__Origens__0=https://levante.exemplo.com

# --- Runtime / observabilidade ---
ASPNETCORE_ENVIRONMENT=Production
Kestrel__Endpoints__Http__Url=http://+:8080
# OTLP opcional (ausente = sem export). Na stack conjunta: http://lgtm:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4317
OTEL_SERVICE_NAME=levante-api
